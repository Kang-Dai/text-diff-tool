<launch4jConfig>
  <dontWrapJar>false</dontWrapJar>
  <headerType>gui</headerType>
  <jar>target/text-diff-tool-1.0.0.jar</jar>
  <outfile>target/TextDiffTool.exe</outfile>
  <errTitle>文本比对工具</errTitle>
  <cmdLine>--gui</cmdLine>
  <chdir>.</chdir>
  <priority>normal</priority>
  <downloadUrl>https://www.oracle.com/java/technologies/downloads/#java8</downloadUrl>
  <supportUrl></supportUrl>
  <stayAlive>false</stayAlive>
  <restartOnCrash>false</restartOnCrash>
  <manifest></manifest>
  <icon></icon>
  <classPath>
    <mainClass>com.textdiff.TextDiffTool</mainClass>
  </classPath>
  <jre>
    <path></path>
    <bundledJre64Bit>false</bundledJre64Bit>
    <bundledJreAsFallback>false</bundledJreAsFallback>
    <minVersion>1.8.0</minVersion>
    <maxVersion></maxVersion>
    <jdkPreference>preferJre</jdkPreference>
    <runtimeBits>64/32</runtimeBits>
    <initialHeapSize>128</initialHeapSize>
    <maxHeapSize>512</maxHeapSize>
    <opt>-Dfile.encoding=UTF-8</opt>
  </jre>
  <versionInfo>
    <fileVersion>1.0.0.0</fileVersion>
    <txtFileVersion>1.0.0</txtFileVersion>
    <fileDescription>文本比对工具 - 支持JSON格式化和差异高亮显示</fileDescription>
    <copyright>© 2026</copyright>
    <productVersion>1.0.0.0</productVersion>
    <txtProductVersion>1.0.0</txtProductVersion>
    <productName>文本比对工具</productName>
    <companyName></companyName>
    <internalName>TextDiffTool</internalName>
    <originalFilename>TextDiffTool.exe</originalFilename>
    <trademarks></trademarks>
  </versionInfo>
</launch4jConfig>
